flowchart TD
    Start([Inicio])

    a["Cliente autenticado envia PATCH /dharmas/{dharmasId}"]
    b["Controller extrai userId e dharmasId"]
    c["Service busca dharma por id e userId"]
    d{"Dharmas existe para este usuario?"}
    e["Retorna erro: Dharmas not found"]
    f["MapStruct aplica partialUpdate ignorando campos nulos"]
    g["Persiste alteracoes"]
    h["Retorna DharmasDTO atualizado"]

    i["Cliente autenticado envia PATCH /dharmas/{dharmasId}/hidden"]
    j["Service busca dharma por id e userId"]
    k{"Dharmas existe para este usuario?"}
    l["Retorna erro: Dharmas not found"]
    m["Inverte flag hidden"]
    n["Transacao persiste novo estado"]
    o["Retorna HTTP 204"]
    End([Fim])

    Start --> a --> b --> c --> d
    d -- "Nao" --> e --> End
    d -- "Sim" --> f --> g --> h --> i --> j --> k
    k -- "Nao" --> l --> End
    k -- "Sim" --> m --> n --> o --> End

    classDef flowClass fill:#e3f2fd,stroke:#1565c0,stroke-width:1.5px,color:#0d47a1;
    classDef actionClass fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#1b5e20;
    classDef decisionClass fill:#fff8e1,stroke:#f9a825,stroke-width:1.5px,color:#7f6000;
    classDef endClass fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px,color:#880e4f;

    class a,b,c,h,i,j,o flowClass;
    class f,g,m,n actionClass;
    class d,k decisionClass;
    class e,l actionClass;
    class Start,End endClass;
