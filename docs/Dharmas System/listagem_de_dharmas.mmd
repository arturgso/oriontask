flowchart TD
    Start([Inicio])

    a["Cliente autenticado envia GET /dharmas"]
    b["Controller le query param includeHidden com default false"]
    c["Extrai userId do Authentication"]
    d{"includeHidden=true?"}
    e["Busca todos os dharmas do usuario"]
    f["Busca apenas dharmas com hidden=false"]
    g["Mapper converte lista para DharmasDTO"]
    h["Retorna lista com HTTP 200"]
    End([Fim])

    Start --> a --> b --> c --> d
    d -- "Sim" --> e --> g
    d -- "Nao" --> f --> g
    g --> h --> End

    classDef flowClass fill:#e3f2fd,stroke:#1565c0,stroke-width:1.5px,color:#0d47a1;
    classDef actionClass fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#1b5e20;
    classDef decisionClass fill:#fff8e1,stroke:#f9a825,stroke-width:1.5px,color:#7f6000;
    classDef endClass fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px,color:#880e4f;

    class a,b,c,g,h flowClass;
    class e,f actionClass;
    class d decisionClass;
    class Start,End endClass;
