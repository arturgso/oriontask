    c{"includeArchived=true?"}
    d["Busca todos os projetos do usuario"]
    e["Busca apenas projetos com archived=false"]
    f["Mapper converte lista para ProjectDTO"]
    g["Retorna lista com HTTP 200"]

    h["Cliente autenticado envia GET /projects/{projectId}"]
    i["Service busca projeto por id e userId"]
    j{"Projeto encontrado?"}
    k["Retorna erro: Project not found"]
    l["Busca tasks associadas ao projeto"]
    m["Busca milestones do projeto"]
    n["Mapeia para ProjectDetailsDTO"]
    o["Retorna detalhes com HTTP 200"]
    End([Fim])

    Start --> a --> b --> c
    c -- "Sim" --> d --> f
    c -- "Nao" --> e --> f
    f --> g --> h --> i --> j
    j -- "Nao" --> k --> End
    j -- "Sim" --> l --> m --> n --> o --> End

