flowchart TD
    Start([Inicio])

    a["Cliente autenticado envia POST /projects com title, description e dharmaId"]
    b["ProjectsController extrai userId do Authentication"]
    c["DharmaLookupService valida se o dharma pertence ao usuario"]
    d{"Dharma existe e e do usuario?"}
    e["Retorna erro: Dharma not found"]
    f["Mapper converte NewProjectDTO para entidade Projects"]
    g["Associa projeto ao usuario e ao dharma"]
    h["Persiste projeto no ProjectsRepository"]
    i["Retorna ProjectDTO com HTTP 201"]
    End([Fim])

    Start --> a --> b --> c --> d
    d -- "Nao" --> e --> End
    d -- "Sim" --> f --> g --> h --> i --> End

    classDef flowClass fill:#e3f2fd,stroke:#1565c0,stroke-width:1.5px,color:#0d47a1;
    classDef actionClass fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#1b5e20;
    classDef decisionClass fill:#fff8e1,stroke:#f9a825,stroke-width:1.5px,color:#7f6000;
    classDef endClass fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px,color:#880e4f;

    class a,b,c,i flowClass;
    class f,g,h actionClass;
    class d decisionClass;
    class e actionClass;
    class Start,End endClass;
