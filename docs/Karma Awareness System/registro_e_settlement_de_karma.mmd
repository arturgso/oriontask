flowchart TD
    Start([Inicio])

    a["TasksController recebe PATCH /tasks/{taskId}/done"]
    b["TasksService busca tarefa por id e userId"]
    c{"Status anterior ja era DONE?"}
    d["Encerrar sem duplicar contagem"]
    e["Marca status DONE e define completedAt=now()"]
    f["TasksService chama KarmaService.settleKarma(task)"]
    g["Le KarmaType e EffortLevel da tarefa"]
    h["Converte esforço em peso: LOW=1, MEDIUM=3, HIGH=5"]
    i{"KarmaType?"}
    j["Incrementa karma_action_total do usuario"]
    k["Incrementa karma_people_total do usuario"]
    l["Incrementa karma_thinking_total do usuario"]
    m["Persiste alteracoes no UsersRepository"]
    n["Retorna TaskDTO atualizada"]
    End([Fim])

    Start --> a --> b --> c
    c -- "Sim" --> d --> End
    c -- "Nao" --> e --> f --> g --> h --> i
    i -- "ACTION" --> j --> m
    i -- "PEOPLE" --> k --> m
    i -- "THINKING" --> l --> m
    m --> n --> End

    classDef flowClass fill:#e3f2fd,stroke:#1565c0,stroke-width:1.5px,color:#0d47a1;
    classDef actionClass fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#1b5e20;
    classDef decisionClass fill:#fff8e1,stroke:#f9a825,stroke-width:1.5px,color:#7f6000;
    classDef endClass fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px,color:#880e4f;

    class a,b,f,g,h,n flowClass;
    class e,j,k,l,m actionClass;
    class c,i decisionClass;
    class d actionClass;
    class Start,End endClass;
