flowchart TD
    Start([Inicio])

    a["Validacoes de seguranca emocional (ADHD-friendly)"]
    b{"Nao houve tarefas DONE em 7 dias?"}
    c["Retornar current_state = NEUTRAL"]
    d["Omitir mensagens de falha ou 'streak lost'"]
    e["Nao aplicar penalidades por inatividade"]
    f{"Tarefa DONE foi deletada?"}
    g["Manter legacy_totals sem alteracao"]
    h["Karma historico nao e reversivel"]
    i{"Limite de tarefas em NOW atingido (5)?"}
    j["Novas tarefas entram como WAITING automaticamente"]
    k["Evitar sobrecarga cognitiva"]
    End([Fim])

    Start --> a --> b
    b -- "Sim" --> c --> d --> e --> f
    b -- "Nao" --> f
    f -- "Sim" --> g --> h --> i
    f -- "Nao" --> i
    i -- "Sim" --> j --> k --> End
    i -- "Nao" --> End

    classDef flowClass fill:#e3f2fd,stroke:#1565c0,stroke-width:1.5px,color:#0d47a1;
    classDef actionClass fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#1b5e20;
    classDef decisionClass fill:#fff8e1,stroke:#f9a825,stroke-width:1.5px,color:#7f6000;
    classDef endClass fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px,color:#880e4f;

    class a,c,d,e flowClass;
    class g,h,j,k actionClass;
    class b,f,i decisionClass;
    class Start,End endClass;
