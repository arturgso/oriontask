flowchart TD
    Start([Inicio Scheduler])

    a["Scheduler executa promoteRecentWaitingTasksToNow em intervalo configurado"]
    b["Busca usuarios com pelo menos uma task WAITING"]
    c["Itera por cada userId encontrado"]
    d["Conta quantas tasks do usuario estao em NOW"]
    e{"Usuario ja possui 5 tasks em NOW?"}
    f["Nao promove nenhuma task desse usuario"]
    g["Busca a task WAITING mais recente do usuario"]
    h{"Existe task WAITING?"}
    i["Policy marca task como NOW"]
    j["Persiste task promovida"]
    k["Registra promocao em log"]
    End([Fim])

    Start --> a --> b --> c --> d --> e
    e -- "Sim" --> f --> c
    e -- "Nao" --> g --> h
    h -- "Nao" --> c
    h -- "Sim" --> i --> j --> k --> c
    c --> End

    classDef flowClass fill:#e3f2fd,stroke:#1565c0,stroke-width:1.5px,color:#0d47a1;
    classDef actionClass fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#1b5e20;
    classDef decisionClass fill:#fff8e1,stroke:#f9a825,stroke-width:1.5px,color:#7f6000;
    classDef endClass fill:#fce4ec,stroke:#c2185b,stroke-width:1.5px,color:#880e4f;

    class a,b,c,d flowClass;
    class f,g,i,j,k actionClass;
    class e,h decisionClass;
    class Start,End endClass;
